{
  "store.custom#tallas-productos": {
    "blocks": [
      "flex-layout.row#bloque-principal-tallas-productos",
      "tab-layout#tallas-productos"
    ]
  },
  "flex-layout.row#bloque-principal-tallas-productos": {
    "props": {
      "blockClass": "home-block"
    },
    "children": [
      "flex-layout.col#principal"
    ]
  },
  "flex-layout.col#principal": {
    "props": {
      "blockClass": "CustomCard"
    },
    "children": [
      "rich-text#titulo-principal-tallas-productos"
    ]
  },
  "rich-text#titulo-principal-tallas-productos": {
    "props": {
      "blockClass": "title-custom-locales-page",
      "textAlignment": "CENTER",
      "text": "TALLAS DE PRODUCTOS"
    }
  },
  "tab-layout#tallas-productos": {
    "children": [
      "tab-list#tallas-productos",
      "tab-content#tallas-productos"
    ],
    "props": {
      "blockClass": "tallas-productos",
      "defaultActiveTabId": "tallas-productos1"
    }
  },
  "tab-list#tallas-productos": {
    "props": {
      "blockClass": "home-block"
    },
    "children": [
      "tab-list.item#tallas-productos1",
      "tab-list.item#tallas-productos2",
      "tab-list.item#tallas-productos3",
      "tab-list.item#tallas-productos4",
      "tab-list.item#tallas-productos5",
      "tab-list.item#tallas-productos6",
      "tab-list.item#tallas-productos7",
      "tab-list.item#tallas-productos8",
      "tab-list.item#tallas-productos9",
      "tab-list.item#tallas-productos10",
      "tab-list.item#tallas-productos11",
      "tab-list.item#tallas-productos12"
    ]
  },
  /*Titulos de los Tabs*/
  "tab-list.item#tallas-productos1": {
    "props": {
      "blockClass": "tab-list-item-tallas-productos",
      "tabId": "tallas-productos1",
      "label": "Zapatos Adidas",
      "defaultActiveTab": true
    }
  },
  "tab-list.item#tallas-productos2": {
    "props": {
      "blockClass": "tab-list-item-tallas-productos",
      "tabId": "tallas-productos2",
      "label": "Zapatos Asics"
    }
  },
  "tab-list.item#tallas-productos3": {
    "props": {
      "blockClass": "tab-list-item-tallas-productos",
      "tabId": "tallas-productos3",
      "label": "Zapatos AURIK"
    }
  },
  "tab-list.item#tallas-productos4": {
    "props": {
      "blockClass": "tab-list-item-tallas-productos",
      "tabId": "tallas-productos4",
      "label": "Zapatos CONVERSE"
    }
  },
  "tab-list.item#tallas-productos5": {
    "props": {
      "blockClass": "tab-list-item-tallas-productos",
      "tabId": "tallas-productos5",
      "label": "Zapatos IPANEMA"
    }
  },
  "tab-list.item#tallas-productos6": {
    "props": {
      "blockClass": "tab-list-item-tallas-productos",
      "tabId": "tallas-productos6",
      "label": "Zapatos LOTTO"
    }
  },
  "tab-list.item#tallas-productos7": {
    "props": {
      "blockClass": "tab-list-item-tallas-productos",
      "tabId": "tallas-productos7",
      "label": "Zapatos NEW BALANCE"
    }
  },
  "tab-list.item#tallas-productos8": {
    "props": {
      "blockClass": "tab-list-item-tallas-productos",
      "tabId": "tallas-productos8",
      "label": "Zapatos REBOOK ACT"
    }
  },
  "tab-list.item#tallas-productos9": {
    "props": {
      "blockClass": "tab-list-item-tallas-productos",
      "tabId": "tallas-productos9",
      "label": "Zapatos REEBOK"
    }
  },
  "tab-list.item#tallas-productos10": {
    "props": {
      "blockClass": "tab-list-item-tallas-productos",
      "tabId": "tallas-productos10",
      "label": "Zapatos RIDER"
    }
  },
  "tab-list.item#tallas-productos11": {
    "props": {
      "blockClass": "tab-list-item-tallas-productos",
      "tabId": "tallas-productos11",
      "label": "Zapatos SPALDING"
    }
  },
  "tab-list.item#tallas-productos12": {
    "props": {
      "blockClass": "tab-list-item-tallas-productos",
      "tabId": "tallas-productos12",
      "label": "Zapatos TIMBERLAND"
    }
  },
  /*Contenido de los Tabs*/
  "tab-content#tallas-productos": {
    "props": {
      "blockClass": "home-block"
    },
    "children": [
      "tab-content.item#tallas-productos1",
      "tab-content.item#tallas-productos2",
      "tab-content.item#tallas-productos3",
      "tab-content.item#tallas-productos4",
      "tab-content.item#tallas-productos5",
      "tab-content.item#tallas-productos6",
      "tab-content.item#tallas-productos7",
      "tab-content.item#tallas-productos8",
      "tab-content.item#tallas-productos9",
      "tab-content.item#tallas-productos10",
      "tab-content.item#tallas-productos11",
      "tab-content.item#tallas-productos12"
    ]
  },
  "tab-content.item#tallas-productos1": {
    "children": [
      "list-context.image-list#adidas"
    ],
    "props": {
      "tabId": "tallas-productos1"
    }
  },
  "tab-content.item#tallas-productos2": {
    "children": [
      "list-context.image-list#asics"
    ],
    "props": {
      "tabId": "tallas-productos2"
