  /*SLIDERS*/
  /*Zapatos Adidas */
  "list-context.image-list#adidas": {
    "title": "Carrusel Adidas",
    "children": [
      "slider-layout#slides-images-adidas"
    ],
    "props": {
      "preload": true,
      "images": [
        {
          "image": "https://kaosport.vtexassets.com/assets/vtex.file-manager-graphql/images/15470dde-81a9-48e7-8a64-d522f03405ce___27334efd52dbac7edea1d75f749954a4.png"
        },
        {
          "image": "https://kaosport.vtexassets.com/assets/vtex.file-manager-graphql/images/b38d711e-2b20-4c4c-8663-99d09ebb9a9f___74b550e182368824fb516dc24e14dcb4.png"
        }
      ]
    }
  },
  "slider-layout#slides-images-adidas": {
    "props": {
      "itemsPerPage": {
        "desktop": 1,
        "tablet": 1,
        "phone": 1
      },
      "showNavigationArrows": "desktopOnly",
      "blockClass": "carousel-tallas-productos"
    }
  },
